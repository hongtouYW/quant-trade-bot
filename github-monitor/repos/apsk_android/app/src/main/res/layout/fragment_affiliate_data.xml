<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginBottom="20dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/panel_filter"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp" />
    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/textView_downline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/pingfang_sc_semi_bold"
                android:text="@string/affiliate_data_downline_template"
                android:textColor="@color/white_FFFFFF"
                android:textSize="14sp" />

            <com.dj.user.widget.ExpandableHeightGridView
                android:id="@+id/gridView_downline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:horizontalSpacing="8dp"
                android:numColumns="3"
                android:stretchMode="columnWidth"
                android:verticalSpacing="8dp" />

            <TextView
                android:id="@+id/textView_team"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/pingfang_sc_semi_bold"
                android:text="@string/affiliate_data_team"
                android:textColor="@color/white_FFFFFF"
                android:textSize="14sp" />

            <com.dj.user.widget.ExpandableHeightGridView
                android:id="@+id/gridView_team_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:horizontalSpacing="8dp"
                android:numColumns="2"
                android:stretchMode="columnWidth"
                android:verticalSpacing="8dp" />

            <com.dj.user.widget.ExpandableHeightGridView
                android:id="@+id/gridView_team_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:horizontalSpacing="8dp"
                android:numColumns="3"
                android:stretchMode="columnWidth"
                android:verticalSpacing="8dp" />

            <com.dj.user.widget.ExpandableHeightGridView
                android:id="@+id/gridView_team_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:horizontalSpacing="8dp"
                android:numColumns="2"
                android:stretchMode="columnWidth"
                android:verticalSpacing="8dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>