<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:id="@+id/panel_data"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.dj.user.widget.ExpandableHeightListView
                    android:id="@+id/listView_redeem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="8dp"
                    android:listSelector="@android:color/transparent"
                    android:padding="16dp" />

                <com.dj.user.widget.BlackTextButton
                    android:id="@+id/button_redeem_all"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="16dp"
                    android:text="@string/player_transfer_one_click" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <include
        android:id="@+id/panel_no_data"
        layout="@layout/view_no_data"
        android:visibility="gone" />

    <include
        android:id="@+id/panel_loading"
        layout="@layout/view_loading"
        android:visibility="gone" />
</FrameLayout>