<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/view_toolbar" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:fontFamily="@font/pingfang_sc_semi_bold"
                    android:text="@string/find_us_save_web_label"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pingfang_sc_regular"
                    android:text="@string/find_us_save_web_desc"
                    android:textColor="@color/gray_BCBCBC"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_phone"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textView_domains"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:autoLink="web"
                    android:fontFamily="@font/pingfang_sc_regular"
                    android:lineSpacingExtra="4sp"
                    android:padding="16dp"
                    android:textColor="@color/orange_F8AF07"
                    android:textSize="14sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/blue_354B9C" />

                <LinearLayout
                    android:id="@+id/panel_home_website"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"/>

                <com.dj.user.widget.BlackTextButton
                    android:id="@+id/button_save_address"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginVertical="16dp"
                    android:text="@string/find_us_save" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:fontFamily="@font/pingfang_sc_semi_bold"
                    android:text="@string/find_us_save_email_label"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pingfang_sc_regular"
                    android:text="@string/find_us_save_email_desc"
                    android:textColor="@color/gray_BCBCBC"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_phone"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:text="@string/find_us_official"
                            android:textColor="@color/gray_BCBCBC"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/textView_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="10dp"
                            android:autoLink="email"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:textColor="@color/orange_F8AF07"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/imageView_copy_email"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_copy" />
                    </LinearLayout>
                </LinearLayout>

                <com.dj.user.widget.BlackTextButton
                    android:id="@+id/button_save_email"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginVertical="16dp"
                    android:text="@string/find_us_save" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>