<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/panel_item"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/panel_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.35"
            android:fontFamily="@font/pingfang_sc_medium"
            android:gravity="center"
            android:text="有效数据"
            android:textColor="@color/blue_6F8EFF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.2"
            android:fontFamily="@font/pingfang_sc_medium"
            android:gravity="center"
            android:text="业绩"
            android:textColor="@color/blue_6F8EFF"
            android:textSize="12sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.45"
            android:fontFamily="@font/pingfang_sc_medium"
            android:gravity="center"
            android:text="每万返佣金额"
            android:textColor="@color/blue_6F8EFF"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panel_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView_col_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.35"
            android:fontFamily="@font/pingfang_sc_regular"
            android:gravity="center"
            android:text="@string/placeholder_count"
            android:textColor="@color/white_FFFFFF"
            android:textSize="10sp"
            tools:ignore="SmallSp" />

        <TextView
            android:id="@+id/textView_col_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.2"
            android:fontFamily="@font/pingfang_sc_regular"
            android:gravity="center"
            android:text="1.00"
            android:textColor="@color/white_FFFFFF"
            android:textSize="10sp"
            tools:ignore="SmallSp" />

        <TextView
            android:id="@+id/textView_col_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.45"
            android:fontFamily="@font/pingfang_sc_regular"
            android:gravity="center"
            android:text="25.00"
            android:textColor="@color/orange_F8AF07"
            android:textSize="10sp"
            tools:ignore="SmallSp" />
    </LinearLayout>
</LinearLayout>