<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/view_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:layout_width="231dp"
                android:layout_height="183dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:contentDescription="@string/cd_icon"
                android:src="@drawable/img_affiliate_earn" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-16dp"
                android:background="@color/blue_122346"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_transaction_details"
                    android:orientation="vertical"
                    android:paddingVertical="16dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginEnd="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/panel_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/textView_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="5dp"
                                android:fontFamily="@font/pingfang_sc_regular"
                                android:text="@string/affiliate_code_default_label"
                                android:textColor="@color/yellow_FFFC86"
                                android:textSize="14sp" />

                            <ImageView
                                android:id="@+id/imageView_edit"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/cd_icon"
                                android:src="@drawable/ic_edit" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/panel_label_edit"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <EditText
                                android:id="@+id/editText_label"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="5dp"
                                android:layout_weight="1"
                                android:background="@android:color/transparent"
                                android:fontFamily="@font/pingfang_sc_regular"
                                android:hint="@string/affiliate_code_default_label"
                                android:inputType="text"
                                android:text="@string/affiliate_code_default_label"
                                android:textColor="@color/yellow_FFFC86"
                                android:textColorHint="@color/yellow_FFFC86_50a"
                                android:textSize="14sp" />

                            <ImageView
                                android:id="@+id/imageView_tick"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/cd_icon"
                                android:src="@drawable/ic_tick" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="10dp"
                            android:layout_weight="0.4"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:gravity="end"
                            android:lines="1"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:text="@string/affiliate_code_default"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/imageView_default"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_check_selected" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/blue_354B9C"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginEnd="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:text="@string/affiliate_code_rebate"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:gravity="end"
                            android:lines="1"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="@color/yellow_FFFC86_50a"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/blue_354B9C" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginEnd="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:text="@string/affiliate_code_invitation_code"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/textView_invitation_code"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="10dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:gravity="end"
                            android:lines="1"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="@color/yellow_FFFC86_50a"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/imageView_copy_code"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_copy" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/blue_354B9C" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginEnd="16dp"
                        android:layout_marginBottom="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:text="@string/affiliate_code_invitation_link"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/textView_invitation_link"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="10dp"
                            android:layout_weight="1"
                            android:ellipsize="marquee"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:singleLine="true"
                            android:textColor="@color/yellow_FFFC86_50a"
                            android:textSize="10sp"
                            tools:ignore="SmallSp" />

                        <ImageView
                            android:id="@+id/imageView_copy_link"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_copy" />
                    </LinearLayout>

                    <com.dj.user.widget.BlackTextButton
                        android:id="@+id/button_invite_now"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:text="@string/affiliate_code_invite_now" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panel_more"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    tools:ignore="UseCompoundDrawables">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:fontFamily="@font/pingfang_sc_semi_bold"
                        android:text="@string/affiliate_code_more"
                        android:textColor="@color/orange_F8AF07"
                        android:textSize="12sp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_icon"
                        android:src="@drawable/ic_chev_right_orange" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:id="@+id/panel_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    tools:ignore="UseCompoundDrawables">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/pingfang_sc_semi_bold"
                        android:text="@string/affiliate_code_summary"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@string/cd_icon"
                        android:src="@drawable/ic_chev_right_orange" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="81dp"
                    android:layout_marginBottom="40dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rounded_blue"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_semi_bold"
                            android:gravity="center"
                            android:text="@string/affiliate_code_team_count"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/textView_team_count"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_semi_bold"
                            android:gravity="center"
                            android:text="@string/placeholder_count"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="24sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rounded_blue"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_semi_bold"
                            android:gravity="center"
                            android:text="@string/affiliate_code_transacted_count"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/textView_traded_count"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_semi_bold"
                            android:gravity="center"
                            android:text="@string/placeholder_count"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="24sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rounded_blue"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_semi_bold"
                            android:gravity="center"
                            android:text="@string/affiliate_code_my_rebate"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/textView_amount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_semi_bold"
                            android:gravity="center"
                            android:text="@string/placeholder_amount"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="24sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>