        <!--            app:dotsWidthFactor="2"-->
        <!--            app:progressMode="false"-->
        <!--            app:selectedDotColor="@color/orange_F8AF07" />-->
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:gravity="bottom"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:layout_marginStart="14dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/cd_image"
                    android:src="@drawable/img_logo_tab" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <RelativeLayout
                    android:id="@+id/panel_notification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:id="@+id/imageView_notification"
                        android:layout_width="20dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/cd_icon"
                        android:paddingVertical="14dp"
                        android:src="@drawable/ic_notification_circled" />

                    <TextView
                        android:id="@+id/textView_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="-8dp"
                        android:layout_toEndOf="@id/imageView_notification"
                        android:background="@drawable/bg_badge_red"
                        android:fontFamily="@font/lato_regular"
                        android:gravity="center"
                        android:lines="1"
                        android:maxLines="1"
                        android:minWidth="16dp"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="2dp"
                        android:singleLine="true"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="69dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_details"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textView_username"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/pingfang_sc_semi_bold"
                    android:textColor="@color/orange_F8AF07"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/imageView_vip"
                    android:layout_width="50dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/cd_icon"
                    android:src="@drawable/vip_0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:fontFamily="@font/lato_regular"
                    android:text="@string/home_balance"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="10sp"
                    tools:ignore="SmallSp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textView_currency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-4dp"
                        android:layout_marginEnd="4dp"
                        android:fontFamily="@font/arial_regular"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/textView_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/arial_bold"
                        android:textSize="24sp" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/panel_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/cd_image"
                        android:src="@drawable/bg_withdraw_all" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:id="@+id/imageView_refresh"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_withdraw_all" />

                        <TextView
                            android:id="@+id/textView_refresh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_semi_bold"
                            android:text="@string/home_withdraw_all"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_action_short"
            android:gravity="center"
            android:orientation="vertical">

            <GridView
                android:id="@+id/gridView_profile_action"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:horizontalSpacing="0dp"
                android:numColumns="4"
                android:stretchMode="columnWidth"
                android:verticalSpacing="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_slider"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_slider"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView_slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:fontFamily="@font/pingfang_sc_regular"
                android:marqueeRepeatLimit="marquee_forever"
                android:paddingHorizontal="10dp"
                android:singleLine="true"
                android:text="+60****2131 充值了 RM 1000 , +60****7788 赢了 RM 900， +60****7788 提现 RM 123120"
                android:textColor="@color/white_FFFFFF"
                android:textSize="10sp"
                tools:ignore="SmallSp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="6dp"
            android:orientation="vertical">

            <!--        <LinearLayout-->
            <!--            android:layout_width="81dp"-->
            <!--            android:layout_height="wrap_content"-->
            <!--            android:background="@drawable/bg_category"-->
            <!--            android:orientation="vertical">-->

            <!--            <ListView-->
            <!--                android:id="@+id/listView_category"-->
            <!--                android:layout_width="match_parent"-->
            <!--                android:layout_height="wrap_content"-->
            <!--                android:divider="@android:color/transparent"-->
            <!--                android:dividerHeight="5dp"-->
            <!--                android:listSelector="@android:color/transparent"-->
            <!--                android:padding="8dp" />-->
            <!--        </LinearLayout>-->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView_yxi_category"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="10dp"
                android:clipToPadding="false"
                android:scrollbars="none" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/panel_data"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp"
                    android:visibility="gone">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView_yxi_provider"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginBottom="13dp"
                        android:clipToPadding="false"
                        android:scrollbars="vertical" />

                    <!--                <GridView-->
                    <!--                    android:id="@+id/gridView_yxi"-->
                    <!--                    android:layout_width="match_parent"-->
                    <!--                    android:layout_height="match_parent"-->
                    <!--                    android:gravity="center"-->
                    <!--                    android:horizontalSpacing="0dp"-->
                    <!--                    android:numColumns="4"-->
                    <!--                    android:stretchMode="columnWidth"-->
                    <!--                    android:verticalSpacing="12dp" />-->
                </LinearLayout>

                <include
                    android:id="@+id/panel_no_data"
                    layout="@layout/view_no_data"
                    android:visibility="gone" />

                <include
                    android:id="@+id/panel_loading"
                    layout="@layout/view_loading"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>