<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/view_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="25dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="20dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp"
                        android:fontFamily="@font/pingfang_sc_thin"
                        android:text="@string/withdraw_credit"
                        android:textColor="@color/gray_6E6E6E" />

                    <RelativeLayout
                        android:layout_width="128dp"
                        android:layout_height="24dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/cd_image"
                            android:src="@drawable/bg_balance_long" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="26dp"
                                android:layout_height="1dp" />

                            <TextView
                                android:id="@+id/textView_balance"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:fontFamily="@font/pingfang_sc_medium"
                                android:gravity="center"
                                android:text="@string/placeholder_amount"
                                android:textColor="@color/white_FFFFFF"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp"
                        android:fontFamily="@font/pingfang_sc_thin"
                        android:text="@string/withdraw_point"
                        android:textColor="@color/gray_6E6E6E" />

                    <RelativeLayout
                        android:layout_width="128dp"
                        android:layout_height="24dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/cd_image"
                            android:src="@drawable/bg_point_long" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="26dp"
                                android:layout_height="1dp" />

                            <TextView
                                android:id="@+id/textView_point"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:fontFamily="@font/pingfang_sc_medium"
                                android:gravity="center"
                                android:text="@string/placeholder_amount"
                                android:textColor="@color/white_FFFFFF"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/imageView_refresh"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom"
                    android:contentDescription="@string/cd_icon"
                    android:src="@drawable/ic_refresh_player" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="@color/blue_354B9C" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="@font/pingfang_sc_regular"
                    android:text="@string/withdraw_id"
                    android:textColor="@color/gray_6E6E6E"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/textView_id"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/bg_edit_text_transparent"
                    android:fontFamily="@font/pingfang_sc_regular"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="@font/pingfang_sc_regular"
                    android:text="@string/withdraw_enter_amount"
                    android:textColor="@color/gray_6E6E6E"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/panel_amount_input"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_edit_text_transparent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_icon"
                        android:src="@drawable/ic_dollar" />

                    <EditText
                        android:id="@+id/editText_amount"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="10dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:hint="@string/placeholder_amount"
                        android:inputType="numberDecimal"
                        android:textColor="@color/orange_F8AF07"
                        android:textColorHint="@color/yellow_FFFC86_50a"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textView_all"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_button_orange"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:gravity="center"
                        android:paddingHorizontal="10dp"
                        android:text="@string/withdraw_all"
                        android:textColor="@color/black_000000"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textView_percentage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pingfang_sc_regular"
                    android:text="@string/withdraw_percentage"
                    android:textColor="@color/gray_6E6E6E"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/textView_withdrawable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="@font/pingfang_sc_regular"
                    android:text="@string/withdraw_withdrawable"
                    android:textColor="@color/gray_E9E9E9"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="25dp"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/pingfang_sc_regular"
                    android:text="@string/withdraw_method"
                    android:textColor="@color/gray_6E6E6E"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginBottom="25dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textView_bank"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tab_start"
                        android:fontFamily="@font/pingfang_sc_medium"
                        android:gravity="center"
                        android:text="@string/withdraw_submit_request"
                        android:textColor="@color/black_000000"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textView_qr"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tab_end_bordered"
                        android:fontFamily="@font/pingfang_sc_medium"
                        android:gravity="center"
                        android:text="@string/withdraw_shop_qr"
                        android:textColor="@color/orange_FFBC00"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_bank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:id="@+id/panel_bank_form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:text="@string/withdraw_add_bank"
                        android:textColor="@color/gray_6E6E6E"
                        android:textSize="12sp" />


                    <LinearLayout
                        android:id="@+id/panel_field_bank"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_edit_text_transparent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:id="@+id/textView_field_bank_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:text="@string/withdraw_choose_bank"
                            android:textColor="@color/yellow_FFFC86_50a"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="8dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_chev_right_gradient" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:text="@string/withdraw_bank_account_name"
                        android:textColor="@color/gray_6E6E6E"
                        android:textSize="12sp" />

                    <com.dj.user.widget.RoundedEditTextView
                        android:id="@+id/editText_account_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:text="@string/withdraw_add_bank_account"
                        android:textColor="@color/gray_6E6E6E"
                        android:textSize="12sp" />

                    <com.dj.user.widget.RoundedEditTextView
                        android:id="@+id/editText_account_no"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="30dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panel_bank_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/pingfang_sc_regular"
                            android:text="@string/withdraw_added_bank"
                            android:textColor="@color/gray_6E6E6E"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:id="@+id/panel_change_account"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            tools:ignore="UseCompoundDrawables">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/pingfang_sc_regular"
                                android:text="@string/withdraw_change_bank_account"
                                android:textColor="@color/orange_FFBC00"
                                android:textSize="12sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@string/cd_icon"
                                android:src="@drawable/ic_chev_right_gradient" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textView_bank_name"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="15dp"
                        android:background="@drawable/bg_edit_text_transparent"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:text="@string/withdraw_bank_account_name"
                        android:textColor="@color/gray_6E6E6E"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/textView_account_name"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="15dp"
                        android:background="@drawable/bg_edit_text_transparent"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:text="@string/withdraw_added_bank_account"
                        android:textColor="@color/gray_6E6E6E"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/textView_account_no"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="34dp"
                        android:background="@drawable/bg_edit_text_transparent"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.dj.user.widget.BlackTextButton
                    android:id="@+id/button_proceed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_marginBottom="16dp"
                    android:text="@string/withdraw_next" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_qr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:visibility="gone">

                <com.dj.user.widget.BlackTextButton
                    android:id="@+id/button_generate_qr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_marginBottom="16dp"
                    android:text="@string/withdraw_generate_qr" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>