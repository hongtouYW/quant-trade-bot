<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/panel_item"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/panel_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="40dp"
            android:fontFamily="@font/pingfang_sc_regular"
            android:gravity="end"
            android:text="@string/vip_header_level"
            android:textColor="@color/blue_6F8EFF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:fontFamily="@font/pingfang_sc_semi_bold"
            android:gravity="center"
            android:text="@string/vip_header_progress"
            android:textColor="@color/blue_6F8EFF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.4"
            android:fontFamily="@font/pingfang_sc_semi_bold"
            android:gravity="center"
            android:text="@string/vip_header_reward"
            android:textColor="@color/blue_6F8EFF"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panel_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageView_icon"
            android:layout_width="50dp"
            android:layout_height="20dp"
            android:layout_marginEnd="40dp"
            android:contentDescription="@string/cd_icon" />

        <TextView
            android:id="@+id/textView_target"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="0.6"
            android:fontFamily="@font/pingfang_sc_regular"
            android:gravity="center"
            android:textColor="@color/white_FFFFFF"
            android:textSize="14sp" />

        <RelativeLayout
            android:id="@+id/panel_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="0.6"
            android:gravity="center">

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="111dp"
                android:layout_height="16dp"
                android:layout_centerInParent="true"
                android:indeterminate="false"
                android:max="100"
                android:progress="40"
                android:progressDrawable="@drawable/bg_progress" />

            <TextView
                android:id="@+id/textView_progress_target"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/pingfang_sc_medium"
                android:textColor="@color/black_000000"
                android:textSize="10sp"
                tools:ignore="SmallSp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/textView_reward"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.4"
            android:fontFamily="@font/pingfang_sc_regular"
            android:gravity="center"
            android:textColor="@color/white_FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>