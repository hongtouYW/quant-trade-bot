<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/view_toolbar" />

    <!--    <ScrollView-->
    <!--        android:layout_width="match_parent"-->
    <!--        android:layout_height="match_parent"-->
    <!--        android:fillViewport="true">-->

    <!--        <LinearLayout-->
    <!--            android:layout_width="match_parent"-->
    <!--            android:layout_height="wrap_content"-->
    <!--            android:orientation="vertical">-->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="8dp"
        android:fontFamily="@font/pingfang_sc_semi_bold"
        android:text="@string/transaction_filter_range"
        android:textColor="@color/white_FFFFFF"
        android:textSize="14sp" />

    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/flexboxLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:paddingHorizontal="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="0dp"
        app:flexWrap="wrap"
        app:justifyContent="flex_start" />

    <LinearLayout
        android:id="@+id/panel_date_selection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_edit_text_transparent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp">

            <TextView
                android:id="@+id/textView_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/pingfang_sc_regular"
                android:textColor="@color/white_FFFFFF"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/cd_icon"
                android:src="@drawable/ic_chev_down" />
        </LinearLayout>

        <TextView
            android:id="@+id/textView_reset"
            android:layout_width="58dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_button_vip"
            android:fontFamily="@font/pingfang_sc_medium"
            android:gravity="center"
            android:text="@string/transaction_filter_reset"
            android:textColor="@color/black_000000"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/pingfang_sc_semi_bold"
        android:text="@string/transaction_filter_results"
        android:textColor="@color/white_FFFFFF"
        android:textSize="14sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/panel_data"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <ListView
                android:id="@+id/listView_transaction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@color/blue_122346"
                android:divider="@color/blue_354B9C"
                android:dividerHeight="1dp"
                android:listSelector="@android:color/transparent"
                android:paddingStart="16dp"
                android:paddingEnd="0dp" />
        </LinearLayout>

        <include
            android:id="@+id/panel_no_data"
            layout="@layout/view_no_data"
            android:visibility="gone" />

        <include
            android:id="@+id/panel_loading"
            layout="@layout/view_loading"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout><!--    </ScrollView>-->
    <!--</LinearLayout>-->