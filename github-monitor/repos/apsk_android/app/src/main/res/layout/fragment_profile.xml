    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="75dp"
            android:gravity="bottom"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:layout_marginStart="14dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/cd_image"
                    android:src="@drawable/img_logo_tab" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <RelativeLayout
                    android:id="@+id/panel_notification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:id="@+id/imageView_notification"
                        android:layout_width="20dp"
                        android:layout_height="48dp"
                        android:contentDescription="@string/cd_icon"
                        android:paddingVertical="14dp"
                        android:src="@drawable/ic_notification_circled" />

                    <TextView
                        android:id="@+id/textView_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="-8dp"
                        android:layout_toEndOf="@id/imageView_notification"
                        android:background="@drawable/bg_badge_red"
                        android:fontFamily="@font/lato_regular"
                        android:gravity="center"
                        android:lines="1"
                        android:maxLines="1"
                        android:minWidth="16dp"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="2dp"
                        android:singleLine="true"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="69dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_details"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textView_username"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/pingfang_sc_semi_bold"
                    android:textColor="@color/orange_F8AF07"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/imageView_vip"
                    android:layout_width="50dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/cd_icon"
                    android:src="@drawable/vip_0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:fontFamily="@font/lato_regular"
                    android:text="@string/home_balance"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="10sp"
                    tools:ignore="SmallSp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textView_currency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="-4dp"
                        android:layout_marginEnd="4dp"
                        android:fontFamily="@font/arial_regular"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/textView_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/arial_bold"
                        android:textSize="24sp" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/panel_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/cd_image"
                        android:src="@drawable/bg_withdraw_all" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:id="@+id/imageView_refresh"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_withdraw_all" />

                        <TextView
                            android:id="@+id/textView_refresh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_semi_bold"
                            android:text="@string/home_withdraw_all"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="128dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_action_long"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <GridView
                android:id="@+id/gridView_profile_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:horizontalSpacing="0dp"
                android:numColumns="4"
                android:stretchMode="columnWidth"
                android:verticalSpacing="8dp" />
        </LinearLayout>

        <ListView
            android:id="@+id/listView_section_general"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@color/blue_122346"
            android:divider="@color/blue_354B9C"
            android:dividerHeight="1dp"
            android:listSelector="@android:color/transparent"
            android:paddingStart="16dp"
            android:paddingEnd="0dp" />
    </LinearLayout>
</RelativeLayout>