<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/textView_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/pingfang_sc_regular"
        android:text="@string/find_us_web_template"
        android:textColor="@color/gray_BCBCBC"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textView_web"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_weight="1"
        android:autoLink="web"
        android:ellipsize="marquee"
        android:fontFamily="@font/pingfang_sc_regular"
        android:marqueeRepeatLimit="marquee_forever"
        android:singleLine="true"
        android:textColor="@color/orange_F8AF07"
        android:textSize="14sp" />

    <ImageView
        android:id="@+id/imageView_copy_web"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="@string/cd_icon"
        android:src="@drawable/ic_copy" />
</LinearLayout>