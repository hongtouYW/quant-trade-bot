                    android:layout_height="38dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginVertical="2dp"
                    android:background="@drawable/bg_button_vip"
                    android:fontFamily="@font/pingfang_sc_medium"
                    android:gravity="center"
