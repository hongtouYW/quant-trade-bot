                            android:layout_height="wrap_content"
                            android:fontFamily="@font/pingfang_sc_semi_bold"
                            android:text="@string/affiliate_share_change_link"
                            android:textColor="@color/orange_F8AF07"
                            android:textSize="12sp" />
                    </LinearLayout>

