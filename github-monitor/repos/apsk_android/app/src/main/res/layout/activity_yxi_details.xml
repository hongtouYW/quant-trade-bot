<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="@string/cd_image"
            android:src="@drawable/img_bg_yxi" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/imageView_left_icon"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_icon"
                android:src="@drawable/ic_arrow_left" />

            <TextView
                android:id="@+id/textView_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:ellipsize="marquee"
                android:fontFamily="@font/pingfang_sc_bold"
                android:marqueeRepeatLimit="marquee_forever"
                android:singleLine="true"
                android:textAllCaps="true"
                android:textColor="@color/white_FFFFFF"
                android:textSize="18sp" />

            <RelativeLayout
                android:layout_width="128dp"
                android:layout_height="24dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_image"
                    android:src="@drawable/bg_point_long" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="26dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/textView_balance"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/pingfang_sc_medium"
                        android:gravity="center"
                        android:text="@string/placeholder_amount"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>
            </RelativeLayout>

            <ImageView
                android:id="@+id/imageView_refresh"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="10dp"
                android:contentDescription="@string/cd_icon"
                android:src="@drawable/ic_refresh_player" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/panel_login_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="-24dp"
        android:background="@drawable/bg_yxi_details"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/pingfang_sc_semi_bold"
                android:text="@string/yxi_details_login_label"
                android:textColor="@color/white_FFFFFF"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/panel_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                tools:ignore="UseCompoundDrawables">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/cd_icon"
                    android:src="@drawable/ic_delete_player" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pingfang_sc_semi_bold"
                    android:text="@string/yxi_details_login_delete"
                    android:textColor="@color/red_FF7073"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:fontFamily="@font/pingfang_sc_semi_bold"
                    android:minWidth="42dp"
                    android:text="@string/yxi_details_login_username"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/panel_login"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_button_bordered_white_30a"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp">

                    <TextView
                        android:id="@+id/textView_login"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="12sp" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:contentDescription="@string/cd_icon"
                        android:src="@drawable/ic_copy" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:fontFamily="@font/pingfang_sc_semi_bold"
                    android:minWidth="42dp"
                    android:text="@string/yxi_details_login_password"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/panel_password"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_button_bordered_white_30a"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp">

                    <TextView
                        android:id="@+id/textView_password"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="12sp" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:contentDescription="@string/cd_icon"
                        android:src="@drawable/ic_copy" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/panel_external_app_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="25dp"
                android:paddingVertical="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    tools:ignore="UseCompoundDrawables">

                    <ImageView
                        android:id="@+id/imageView_yxi_logo"
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/cd_image" />

                    <TextView
                        android:id="@+id/textView_yxi_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pingfang_sc_bold"
                        android:textAllCaps="true"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="18sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textView_yxi_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="26dp"
                    android:fontFamily="@font/pingfang_sc_semi_bold"
                    android:gravity="center"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="16sp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/textView_1"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_step"
                        android:fontFamily="@font/pingfang_sc_semi_bold"
                        android:gravity="center"
                        android:text="@string/yxi_details_step_1_label"
                        android:textColor="@color/black_000000"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/textView_step_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignTop="@id/textView_1"
                        android:layout_marginBottom="1dp"
                        android:layout_toEndOf="@id/textView_1"
                        android:fontFamily="@font/pingfang_sc_semi_bold"
                        android:text="@string/yxi_details_step_1"
                        android:textAllCaps="true"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textView_step_1_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textView_step_1"
                        android:layout_alignStart="@id/textView_step_1"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:lineSpacingExtra="4sp"
                        android:textColor="@color/gray_CECECE"
                        android:textSize="12sp" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/textView_2"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_step"
                        android:fontFamily="@font/pingfang_sc_semi_bold"
                        android:gravity="center"
                        android:text="@string/yxi_details_step_2_label"
                        android:textColor="@color/black_000000"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/textView_step_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignTop="@id/textView_2"
                        android:layout_marginBottom="1dp"
                        android:layout_toEndOf="@id/textView_2"
                        android:fontFamily="@font/pingfang_sc_semi_bold"
                        android:text="@string/yxi_details_step_2"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textView_step_2_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textView_step_2"
                        android:layout_alignStart="@id/textView_step_2"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:lineSpacingExtra="4sp"
                        android:linksClickable="true"
                        android:textColor="@color/gray_CECECE"
                        android:textColorLink="@color/orange_FDB71B"
                        android:textSize="12sp" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/textView_3"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_step"
                        android:fontFamily="@font/pingfang_sc_semi_bold"
                        android:gravity="center"
                        android:text="@string/yxi_details_step_3_label"
                        android:textColor="@color/black_000000"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/textView_step_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignTop="@id/textView_3"
                        android:layout_marginBottom="1dp"
                        android:layout_toEndOf="@id/textView_3"
                        android:fontFamily="@font/pingfang_sc_semi_bold"
                        android:text="@string/yxi_details_step_3"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textView_step_3_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/textView_step_3"
                        android:layout_alignStart="@id/textView_step_3"
                        android:fontFamily="@font/pingfang_sc_regular"
                        android:lineSpacingExtra="4sp"
                        android:text="@string/yxi_details_step_3_desc"
                        android:textColor="@color/gray_CECECE"
                        android:textSize="12sp" />
                </RelativeLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_yxi_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    tools:ignore="UseCompoundDrawables">

                    <ImageView
                        android:id="@+id/imageView_yxi_icon"
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/cd_image" />

                    <TextView
                        android:id="@+id/textView_yxi_list_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pingfang_sc_bold"
                        android:textAllCaps="true"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="18sp" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:id="@+id/panel_data"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingHorizontal="4dp"
                        android:visibility="gone">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerView_yxi"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clipToPadding="false"
                            android:scrollbars="vertical" />
                        <!--                        <com.dj.user.widget.ExpandableHeightGridView-->
                        <!--                            android:id="@+id/gridView_yxi"-->
                        <!--                            android:layout_width="match_parent"-->
                        <!--                            android:layout_height="wrap_content"-->
                        <!--                            android:gravity="center"-->
                        <!--                            android:horizontalSpacing="0dp"-->
                        <!--                            android:numColumns="4"-->
                        <!--                            android:stretchMode="columnWidth"-->
                        <!--                            android:verticalSpacing="15dp" />-->
                    </LinearLayout>

                    <include
                        android:id="@+id/panel_no_data"
                        layout="@layout/view_no_data"
                        android:visibility="gone" />

                    <include
                        android:id="@+id/panel_loading"
                        layout="@layout/view_loading"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/panel_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="@drawable/bg_buttons" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <TextView
                android:id="@+id/textView_start_yxi"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:alpha="0.5"
                android:background="@drawable/bg_bottom_rounded_gradient_green"
                android:fontFamily="@font/pingfang_sc_semi_bold"
                android:gravity="center"
                android:text="@string/yxi_details_start"
                android:textColor="@color/black_000000"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textView_top_up"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_bordered_orange"
                android:fontFamily="@font/pingfang_sc_semi_bold"
                android:gravity="center"
                android:text="@string/yxi_details_top_up"
                android:textColor="@color/orange_F8AF07"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textView_transfer"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_bordered_orange"
                android:fontFamily="@font/pingfang_sc_semi_bold"
                android:gravity="center"
                android:text="@string/yxi_details_transfer"
                android:textColor="@color/orange_F8AF07"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>