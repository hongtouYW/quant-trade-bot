<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/panel_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.35"
                android:fontFamily="@font/pingfang_sc_regular"
                android:gravity="center"
                android:text="@string/player_transfer_header_yxi"
                android:textColor="@color/blue_6F8EFF"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.25"
                android:fontFamily="@font/pingfang_sc_semi_bold"
                android:gravity="center"
                android:text="@string/player_transfer_header_points"
                android:textColor="@color/blue_6F8EFF"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:fontFamily="@font/pingfang_sc_semi_bold"
                android:gravity="center"
                android:text="@string/player_transfer_header_transfer"
                android:textColor="@color/blue_6F8EFF"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView_yxi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="0.35"
                android:ellipsize="marquee"
                android:fontFamily="@font/pingfang_sc_regular"
                android:gravity="center"
                android:singleLine="true"
                android:textColor="@color/white_FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textView_points"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.25"
                android:fontFamily="@font/pingfang_sc_regular"
                android:gravity="center"
                android:text="@string/placeholder_amount"
                android:textColor="@color/white_FFFFFF"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/cd_icon"
                    android:visibility="invisible" />

                <TextView
                    android:id="@+id/textView_transfer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/pingfang_sc_regular"
                    android:gravity="center"
                    android:text="@string/placeholder_amount"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/imageView_chev"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/cd_icon"
                    android:src="@drawable/ic_chev_down_gradient" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/view_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/blue_354B9C" />
</LinearLayout>