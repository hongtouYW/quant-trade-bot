<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/view_toolbar" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/panel_data"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <ScrollView
                android:id="@+id/scrollView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.dj.user.widget.ExpandableHeightListView
                        android:id="@+id/listView_affiliate_code"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="@android:color/transparent"
                        android:divider="@android:color/transparent"
                        android:dividerHeight="20dp"
                        android:listSelector="@android:color/transparent"
                        android:padding="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/pingfang_sc_semi_bold"
                        android:padding="30dp"
                        android:text="没有更多内容了"
                        android:textColor="@color/gray_BCBCBC"
                        android:textSize="12sp" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <include
            android:id="@+id/panel_no_data"
            layout="@layout/view_no_data"
            android:visibility="gone" />

        <include
            android:id="@+id/panel_loading"
            layout="@layout/view_loading"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>