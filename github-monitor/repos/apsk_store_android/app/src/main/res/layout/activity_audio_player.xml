<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="25dp"
            android:layout_marginEnd="25dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Left Icon -->
            <ImageView
                android:id="@+id/imageView_left_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back" />

            <!-- Title (center X and vertically aligned to left icon) -->
            <TextView
                android:id="@+id/textView_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="21dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="现在播放"
                android:textColor="@color/white_FFFFFF"
                android:textSize="20sp" />

            <!-- Right Icon -->
            <ImageView
                android:id="@+id/imageView_right_icon"
                android:layout_width="24dp"
                android:layout_height="24dp" />
        </LinearLayout>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginBottom="27dp"
                android:background="@drawable/bg_player">
                <!-- Album art (we will animate this) -->
                <ImageView
                    android:id="@+id/imageView_album"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_centerInParent="true"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/ic_vinyl" />
            </RelativeLayout>
            <!-- Song title -->
            <TextView
                android:id="@+id/textView_songTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/imageView_album"
                android:layout_marginTop="20dp"
                android:ellipsize="marquee"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:gravity="center"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                android:singleLine="true"
                android:text="中山DJ荣少-国语粤语Electro给我一次"
                android:textColor="#F8AF07"
                android:textSize="20sp" />

            <!-- Artist name -->
            <TextView
                android:id="@+id/textView_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/textView_songTitle"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="中山DJ荣少"
                android:textColor="#6E6E6E"
                android:textSize="16sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="15dp"
                android:paddingHorizontal="15dp">

                <ImageButton
                    android:id="@+id/btn_volume"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentStart="true"
                    android:background="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_volume" />

                <ImageButton
                    android:id="@+id/btn_fav"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:background="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_fav" />
            </RelativeLayout>
            <!-- SeekBar and times -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <TextView
                    android:id="@+id/textView_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#CCCCCC" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/textView_end"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="04:00"
                    android:textColor="#CCCCCC" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:layout_marginTop="20dp"
                android:progress="80"
                android:progressBackgroundTint="#4DFFFC86"
                android:progressTint="#F8AF06"
                android:thumbTint="#F8AF06" />

            <!-- Control buttons -->
            <RelativeLayout
                android:id="@+id/controlPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="15dp">

                <ImageButton
                    android:id="@+id/btn_shuffle"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentStart="true"
                    android:background="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_shuffle_off" />

                <ImageButton
                    android:id="@+id/btn_prev"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_toStartOf="@id/btn_play"
                    android:background="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_prev" />

                <ImageButton
                    android:id="@+id/btn_play"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_centerInParent="true"
                    android:layout_marginHorizontal="38dp"
                    android:background="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_play" />

                <ImageButton
                    android:id="@+id/btn_next"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_toEndOf="@id/btn_play"
                    android:background="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_next" />

                <ImageButton
                    android:id="@+id/btn_repeat"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:background="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_repeat_off" />
            </RelativeLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom nav with icons above labels -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_tab"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Home -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="首页"
                android:textColor="@color/white_FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Library -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_album" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="曲库"
                android:textColor="@color/white_FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Rankings -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_list" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="榜单"
                android:textColor="@color/white_FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- My Account -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_mine" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的"
                android:textColor="@color/white_FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
