<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_000122"
    android:gravity="center"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:layout_marginVertical="40dp"
                android:contentDescription="@string/cd_icon" />

            <TextView
                android:id="@+id/textView_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="52dp"
                android:fontFamily="@font/poppins_semi_bold"
                android:gravity="center"
                android:textColor="@color/gold_FFCB22"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/textView_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="52dp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:textColor="@color/gray_C2C3CB"
                android:textSize="20sp" />

            <LinearLayout
                android:id="@+id/panel_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="50dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/panel_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="0.4"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/details_phone"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textView_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="end"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/panel_password_balance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textView_password_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/details_account_balance"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textView_amount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="end"
                        android:text="@string/placeholder_currency_amount"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>

            <com.dj.shop.widget.SolidTextButton
                android:id="@+id/button_solid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <com.dj.shop.widget.BorderedTextButton
                android:id="@+id/button_bordered"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp" />

            <TextView
                android:id="@+id/textView_link_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:fontFamily="@font/poppins_medium"
                android:padding="20dp"
                android:textColor="@color/white_FFFFFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textView_link_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:padding="20dp"
                android:textColor="@color/white_FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>