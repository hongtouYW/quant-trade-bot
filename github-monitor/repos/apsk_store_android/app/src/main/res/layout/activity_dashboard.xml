<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Background image -->
    <ImageView
        android:id="@+id/imageView_bg"
        android:layout_width="match_parent"
        android:layout_height="270dp"
        android:contentDescription="@string/cd_image"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_dashboard" />

    <LinearLayout
        android:id="@+id/panel_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="70dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <!-- Logo -->
        <ImageView
            android:id="@+id/imageView_logo"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/cd_image"
            android:src="@drawable/img_logo_dashboard" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/imageView_search"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="20dp"
            android:contentDescription="@string/cd_icon"
            android:src="@drawable/ic_search_dashboard" />

        <!-- Profile picture -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageView_profile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder"
            app:shapeAppearanceOverlay="@style/CircularImageView" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/imageView_bg"
        android:layout_marginTop="-95dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <!-- Scrollable content starts here -->
            <ScrollView
                android:id="@+id/scrollView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <!-- CardView -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="191dp"
                        android:background="@drawable/bg_card"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="12dp"
                            android:layout_marginEnd="20dp"
                            android:gravity="bottom"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/dashboard_amount"
                                android:textColor="@color/white_FFFFFF"
                                android:textSize="20sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/placeholder_currency"
                                android:textColor="@color/white_FFFFFF"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <LinearLayout
                                android:id="@+id/panel_alert"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_alert"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingHorizontal="20dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="4dp"
                                    android:fontFamily="@font/poppins_regular"
                                    android:text="@string/dashboard_alert"
                                    android:textColor="@color/black_161616"
                                    android:textSize="14sp" />

                                <ImageView
                                    android:layout_width="21dp"
                                    android:layout_height="21dp"
                                    android:contentDescription="@string/cd_icon"
                                    android:src="@drawable/ic_alert" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            tools:ignore="UseCompoundDrawables">

                            <TextView
                                android:id="@+id/textView_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8sp"
                                android:fontFamily="@font/poppins_semi_bold"
                                android:text="@string/placeholder_amount"
                                android:textColor="@color/gold_FFCB22"
                                android:textSize="30sp" />

                            <ImageView
                                android:id="@+id/imageView_amount_toggle"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:contentDescription="@string/cd_icon"
                                android:src="@drawable/ic_home_eye" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/bg_divider_linear" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/panel_income"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="20dp"
                                android:layout_weight="0.4"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    android:id="@+id/textView_today"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_regular"
                                    android:text="@string/dashboard_income"
                                    android:textColor="@color/white_FFFFFF"
                                    android:textSize="15sp" />

                                <TextView
                                    android:id="@+id/textView_income"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_semi_bold"
                                    android:lines="1"
                                    android:text="@string/placeholder_amount_add"
                                    android:textColor="@color/white_FFFFFF"
                                    android:textSize="16sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="20dp"
                                android:layout_weight="0.3"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/textView_yxi_label"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_regular"
                                    android:text="@string/dashboard_yxi_count"
                                    android:textColor="@color/white_FFFFFF"
                                    android:textSize="15sp" />

                                <TextView
                                    android:id="@+id/textView_yxi"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_semi_bold"
                                    android:text="@string/placeholder_count"
                                    android:textColor="@color/white_FFFFFF"
                                    android:textSize="20sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.3"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/textView_player_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_regular"
                                    android:text="@string/dashboard_player_count"
                                    android:textColor="@color/white_FFFFFF"
                                    android:textSize="15sp" />

                                <TextView
                                    android:id="@+id/textView_player"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_semi_bold"
                                    android:text="@string/placeholder_count"
                                    android:textColor="@color/white_FFFFFF"
                                    android:textSize="20sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- GridView for account -->
                    <com.dj.shop.widget.ExpandableHeightGridView
                        android:id="@+id/gridView_account"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp"
                        android:gravity="center"
                        android:horizontalSpacing="18dp"
                        android:numColumns="3"
                        android:padding="0dp"
                        android:stretchMode="columnWidth"
                        android:verticalSpacing="0dp" />

                    <!-- GridView for actions -->
                    <com.dj.shop.widget.ExpandableHeightGridView
                        android:id="@+id/gridView_action"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="40dp"
                        android:layout_marginBottom="20dp"
                        android:gravity="center"
                        android:horizontalSpacing="18dp"
                        android:numColumns="2"
                        android:padding="0dp"
                        android:stretchMode="columnWidth"
                        android:verticalSpacing="18dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:gravity="center"
                        android:text="@string/copyright"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="12sp" />
                </LinearLayout>
            </ScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>
</RelativeLayout>
