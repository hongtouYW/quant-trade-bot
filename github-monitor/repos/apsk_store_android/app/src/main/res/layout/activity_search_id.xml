<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/cd_image"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_transaction" />

    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <include
                android:id="@+id/toolbar"
                layout="@layout/view_toolbar" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="25dp"
                    android:paddingTop="40dp"
                    android:paddingEnd="25dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imageView_yxi"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="12dp"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/cd_image"
                        android:src="@drawable/img_provider_default"
                        app:shapeAppearanceOverlay="@style/Radius6ImageView" />

                    <TextView
                        android:id="@+id/textView_yxi_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:gravity="center"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="27sp" />

                    <com.dj.shop.widget.RoundedEditTextView
                        android:id="@+id/editText_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp" />

                    <com.dj.shop.widget.SolidTextButton
                        android:id="@+id/button_search"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/player_search_button_search" />

                    <TextView
                        android:id="@+id/textView_back"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="60dp"
                        android:layout_marginBottom="40dp"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:text="@string/player_search_button_back"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>