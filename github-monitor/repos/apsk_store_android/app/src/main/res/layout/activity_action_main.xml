<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/cd_image"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_transaction" />

    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <include
                android:id="@+id/toolbar"
                layout="@layout/view_toolbar" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="25dp"
                    android:paddingTop="40dp"
                    android:paddingEnd="25dp">

                    <TextView
                        android:id="@+id/textView_page_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20sp"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:gravity="center"
                        android:textColor="@color/gold_D4AF37"
                        android:textSize="38sp" />

                    <TextView
                        android:id="@+id/textView_page_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="86dp"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="center"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="20sp" />

                    <LinearLayout
                        android:id="@+id/panel_search"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:fontFamily="@font/poppins_regular"
                            android:text="@string/action_main_hint_format"
                            android:textColor="@color/gray_C2C3CB"
                            android:textSize="14sp" />

                        <com.dj.shop.widget.RoundedEditTextView
                            android:id="@+id/editText_search"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/panel_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/panel_country_code"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_edit_text"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingHorizontal="20dp">

                            <TextView
                                android:id="@+id/textView_country_code"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="20sp"
                                android:fontFamily="@font/poppins_regular"
                                android:textColor="@color/white_FFFFFF"
                                android:textSize="16sp" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:contentDescription="@string/cd_icon"
                                android:src="@drawable/ic_chev_down_gold" />
                        </LinearLayout>

                        <com.dj.shop.widget.RoundedEditTextView
                            android:id="@+id/editText_phone"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.75" />
                    </LinearLayout>

                    <com.dj.shop.widget.SolidTextButton
                        android:id="@+id/button_search"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/action_main_button_search" />

                    <View
                        android:id="@+id/imageView_divider"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="60dp"
                        android:background="@drawable/bg_divider_linear" />

                    <TextView
                        android:id="@+id/textView_option_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="60dp"
                        android:layout_marginBottom="40dp"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/textView_option_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="center"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>
</RelativeLayout>