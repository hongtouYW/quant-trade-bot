{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "jeroennoten/laravel-adminlte": "^3.15",
        "kreait/firebase-php": "^7.24",
        "kreait/laravel-firebase": "^6.2",
        "laravel/fortify": "^1.25",
        "laravel/framework": "^12.0",
        "laravel/passport": "13.0",
        "laravel/sanctum": "^4.1",
        "laravel/socialite": "^5.23",
        "laravel/tinker": "^2.10.1",
        "livewire/livewire": "^3.6",
        "nesbot/carbon": "^3.9",
        "pragmarx/google2fa": "^8.0",
        "pragmarx/google2fa-laravel": "*",
        "propaganistas/laravel-phone": "^6.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/access_helpers.php",
            "app/Helpers/database_helpers.php",
            "app/Helpers/date_helpers.php",
            "app/Helpers/general_helpers.php",
            "app/Helpers/permission_helpers.php",
            "app/Helpers/module_helpers.php",
            "app/Helpers/user_helpers.php",
            "app/Helpers/manager_helpers.php",
            "app/Helpers/shop_helpers.php",
            "app/Helpers/member_helpers.php",
            "app/Helpers/payment_helpers.php",
            "app/Helpers/genre_helpers.php",
            "app/Helpers/game_helpers.php",
            "app/Helpers/artist_helpers.php",
            "app/Helpers/vip_helpers.php",
            "app/Helpers/area_helpers.php",
            "app/Helpers/api_helpers.php",
            "app/Helpers/string_helpers.php",
            "app/Helpers/jili_helpers.php",
            "app/Helpers/mega_helpers.php",
            "app/Helpers/onehubx_helpers.php",
            "app/Helpers/fpay_helpers.php",
            "app/Helpers/superpay_helpers.php",
            "app/Helpers/advantplay_helper.php",
            "app/Helpers/telesms_helpers.php",
            "app/Helpers/firebase_helpers.php",
            "app/Helpers/promotion_helpers.php",
            "app/Helpers/chatbot_helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
