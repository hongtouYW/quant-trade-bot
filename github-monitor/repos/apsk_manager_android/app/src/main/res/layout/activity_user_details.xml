<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/view_toolbar_text" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="35dp">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:id="@+id/imageView_profile"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginBottom="10dp"
                    android:contentDescription="@string/cd_image"
                    android:src="@drawable/placeholder_user" />

                <ImageView
                    android:id="@+id/imageView_vip"
                    android:layout_width="50dp"
                    android:layout_height="20dp"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:layout_gravity="center"
                    android:contentDescription="@string/cd_icon"
                    android:src="@drawable/vip_0" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/panel_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <EditText
                    android:id="@+id/editText_phone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@android:color/transparent"
                    android:enabled="false"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:gravity="center"
                    android:inputType="phone"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="27sp" />

                <ImageView
                    android:id="@+id/imageView_edit"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/cd_icon"
                    android:src="@drawable/ic_edit" />

                <ImageView
                    android:id="@+id/imageView_confirm"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@string/cd_icon"
                    android:src="@drawable/ic_tick"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/imageView_cancel"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/cd_icon"
                    android:src="@drawable/ic_edit_cancel"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="35dp"
                android:paddingVertical="50dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/user_details_country"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textView_location"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="end"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="0.4"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/user_details_password"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:gravity="center_vertical|end"
                        android:orientation="horizontal"
                        tools:ignore="UseCompoundDrawables">

                        <TextView
                            android:id="@+id/textView_password"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:fontFamily="@font/poppins_regular"
                            android:gravity="end"
                            android:text="@string/placeholder_password_masked"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="18sp" />

                        <ImageView
                            android:id="@+id/imageView_password_toggle"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_eye_off" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="0.4"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/user_details_id"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textView_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="end"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="0.4"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/user_details_status"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textView_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:gravity="end"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="0.4"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/user_details_created_by"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textView_shop_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="end"
                        android:textColor="@color/gray_BCBCBC"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="0.4"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/user_details_current_balance"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textView_balance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="end"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="0.4"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/user_details_current_point"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textView_points"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="end"
                        android:text="@string/placeholder_amount"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />
                </LinearLayout>

                <!--                <LinearLayout-->
                <!--                    android:layout_width="match_parent"-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:layout_marginBottom="24dp"-->
                <!--                    android:gravity="center_vertical"-->
                <!--                    android:orientation="horizontal">-->

                <!--                    <TextView-->
                <!--                        android:layout_width="0dp"-->
                <!--                        android:layout_height="wrap_content"-->
                <!--                        android:layout_marginEnd="8dp"-->
                <!--                        android:layout_weight="0.4"-->
                <!--                        android:fontFamily="@font/poppins_regular"-->
                <!--                        android:text="@string/user_details_current_exp"-->
                <!--                        android:textColor="@color/gray_C2C3CB"-->
                <!--                        android:textSize="18sp" />-->

                <!--                    <TextView-->
                <!--                        android:id="@+id/textView_experience"-->
                <!--                        android:layout_width="0dp"-->
                <!--                        android:layout_height="wrap_content"-->
                <!--                        android:layout_weight="0.6"-->
                <!--                        android:fontFamily="@font/poppins_regular"-->
                <!--                        android:gravity="end"-->
                <!--                        android:text="@string/placeholder_amount"-->
                <!--                        android:textColor="@color/gray_C2C3CB"-->
                <!--                        android:textSize="18sp" />-->
                <!--                </LinearLayout>-->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="0.4"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/user_details_last_login"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textView_last_logon"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:fontFamily="@font/poppins_regular"
                        android:gravity="end"
                        android:textColor="@color/gray_C2C3CB"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <com.dj.manager.widget.CustomButton
                    android:id="@+id/button_change_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="@string/user_details_change_password" />


                <com.dj.manager.widget.CustomButton
                    android:id="@+id/button_all_yxi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="@string/user_details_all_yxi" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/button_cta"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_button_bordered"
                    android:text="@string/user_details_block"
                    android:textColor="@color/gray_BCBCBC" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
