<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/toolbar"
        layout="@layout/view_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="35dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/shop_balance_current"
                android:textColor="@color/gray_C2C3CB"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textView_balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/white_FFFFFF"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="13dp"
                    android:fontFamily="@font/poppins_regular"
                    android:text="@string/shop_balance_existing_settings"
                    android:textColor="@color/gray_C2C3CB"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/textView_updated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/gray_7B7B7B_70a"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textView_open_balance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/textView_config"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"
                    android:text="@string/shop_balance_modify"
                    android:textColor="@color/gold_D4AF37"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="13dp"
                    android:fontFamily="@font/poppins_regular"
                    android:text="@string/shop_balance_min_settings"
                    android:textColor="@color/gray_C2C3CB"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/textView_min_updated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/gray_7B7B7B_70a"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="60dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textView_min_balance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/textView_min_config"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"
                    android:text="@string/shop_balance_modify"
                    android:textColor="@color/gold_D4AF37"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:text="@string/shop_balance_settings"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="2dp"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:text="@string/placeholder_currency"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="24sp" />

                    <EditText
                        android:id="@+id/editText_selected_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:hint="@string/placeholder_amount"
                        android:inputType="number"
                        android:lines="1"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="@color/gray_7B7B7B"
                        android:textColorHint="@color/gray_7B7B7B"
                        android:textSize="24sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textView_balance_set"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="33dp"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textView_option_100"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_positive_button"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:text="@string/shop_balance_100"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textView_option_200"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_positive_button"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:text="@string/shop_balance_200"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textView_option_2000"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_positive_button"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:text="@string/shop_balance_2000"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textView_option_5000"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_bordered_gold"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:text="@string/shop_balance_5000"
                        android:textColor="@color/gold_D4AF37"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:text="@string/shop_balance_min_settings"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="2dp"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:text="@string/placeholder_currency"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="24sp" />

                    <EditText
                        android:id="@+id/editText_min_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:hint="@string/placeholder_amount"
                        android:inputType="number"
                        android:lines="1"
                        android:maxLines="1"
                        android:padding="0dp"
                        android:singleLine="true"
                        android:textColor="@color/gray_7B7B7B"
                        android:textColorHint="@color/gray_7B7B7B"
                        android:textSize="24sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textView_min_balance_set"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/white_FFFFFF"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="33dp"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textView_min_option_100"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_positive_button"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:text="@string/shop_balance_100"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textView_min_option_200"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_positive_button"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:text="@string/shop_balance_200"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textView_min_option_2000"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_positive_button"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:text="@string/shop_balance_2000"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textView_min_option_5000"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_bordered_gold"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:text="@string/shop_balance_5000"
                        android:textColor="@color/gold_D4AF37"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.dj.manager.widget.CustomButton
                    android:id="@+id/button_submit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/shop_balance_update" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>