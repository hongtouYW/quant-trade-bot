<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_dialog"
    android:orientation="vertical">

    <TextView
        android:id="@+id/textView_cancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="20dp"
        android:fontFamily="@font/poppins_regular"
        android:padding="20dp"
        android:text="取消"
        android:textSize="16sp" />


    <LinearLayout
        android:id="@+id/panel_dates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <!-- Month navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="40dp">

            <LinearLayout
                android:id="@+id/panel_month_year"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textView_month_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="2dp"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:textColor="@color/gold_D4AF37"
                    android:textSize="18sp" />

                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="18dp"
                    android:layout_marginBottom="2dp"
                    android:src="@drawable/ic_chev_right_calendar_gold" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imageView_prev_month"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="20dp"
                    android:src="@drawable/ic_chev_left_calendar" />

                <ImageView
                    android:id="@+id/imageView_next_month"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chev_right_calendar" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/weekDaysContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal" />

        <com.kizitonwose.calendar.view.CalendarView
            android:id="@+id/calendar_view"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginHorizontal="30dp"
            android:layout_marginBottom="30dp"
            app:cv_dayViewResource="@layout/item_calendar_day" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panel_month"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageView_prev_year"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chev_left_calendar" />

            <TextView
                android:id="@+id/textView_year"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_semi_bold"
                android:gravity="center"
                android:text="2025"
                android:textColor="@color/white_FFFFFF"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/imageView_next_year"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chev_right_calendar" />
        </LinearLayout>

        <GridView
            android:id="@+id/gridView_month"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp"
            android:gravity="center"
            android:horizontalSpacing="0dp"
            android:numColumns="3"
            android:paddingHorizontal="30dp"
            android:stretchMode="columnWidth"
            android:verticalSpacing="0dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="35dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView_reset"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:text="消除"
            android:textColor="@color/white_FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/textView_confirm"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_action"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:text="确定"
            android:textColor="@color/gold_D4AF37"
            android:textSize="16sp" />
    </LinearLayout>
</LinearLayout>