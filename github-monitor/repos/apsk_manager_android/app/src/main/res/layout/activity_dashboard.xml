<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:padding="35dp">

            <ImageView
                android:id="@+id/imageView_menu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/cd_icon"
                android:src="@drawable/ic_side_menu" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/imageView_notification"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/cd_icon"
                android:src="@drawable/ic_notification_top" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageView_profile"
                style="@style/CircularImageView"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/placeholder"
                android:visibility="gone" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="35dp"
                    android:paddingVertical="5dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="0.75"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            tools:ignore="UseCompoundDrawables">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/dashboard_balance"
                                android:textColor="@color/white_FFFFFF"
                                android:textSize="14sp" />

                            <ImageView
                                android:layout_width="19dp"
                                android:layout_height="12dp"
                                android:contentDescription="@string/cd_icon"
                                android:src="@drawable/ic_dollar" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:fontFamily="@font/poppins_semi_bold"
                                android:text="@string/placeholder_currency"
                                android:textColor="@color/gold_D4AF37"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/textView_balance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_semi_bold"
                                android:letterSpacing="-0.02"
                                android:text="@string/placeholder_amount"
                                android:textColor="@color/gold_D4AF37"
                                android:textSize="36sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.25"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            tools:ignore="UseCompoundDrawables">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/dashboard_shop_count"
                                android:textColor="@color/white_FFFFFF"
                                android:textSize="14sp" />

                            <ImageView
                                android:layout_width="13dp"
                                android:layout_height="12dp"
                                android:contentDescription="@string/cd_icon"
                                android:src="@drawable/ic_shop" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textView_shop_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:text="@string/placeholder_count"
                            android:textColor="@color/gold_D4AF37"
                            android:textSize="36sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="30dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="35dp"
                    android:paddingVertical="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        tools:ignore="UseCompoundDrawables">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:fontFamily="@font/poppins_regular"
                            android:text="@string/dashboard_capital"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_dollar_bag" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:text="@string/placeholder_currency"
                            android:textColor="@color/gold_D4AF37"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/textView_capital"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:letterSpacing="-0.02"
                            android:text="@string/placeholder_amount"
                            android:textColor="@color/gold_D4AF37"
                            android:textSize="36sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <LinearLayout
                        android:id="@+id/panel_search"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_action"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_search" />

                        <TextView
                            android:id="@+id/editText_search"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:singleLine="true"
                            android:text="@string/dashboard_search_hint"
                            android:textColor="@color/gray_717171"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/panel_qr_scan"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_action"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_scan" />
                    </LinearLayout>
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_history"
                    android:paddingHorizontal="23dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/imageView_icon"
                        android:layout_width="22dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@string/cd_icon"
                        android:src="@drawable/ic_history" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/imageView_icon"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:text="@string/dashboard_point_history"
                        android:textColor="@color/gold_D4AF37"
                        android:textSize="18sp" />

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true">

                        <TextView
                            android:id="@+id/textView_next"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:text="@string/dashboard_point_go"
                            android:textColor="@color/gold_D4AF37"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/textView_next"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/poppins_regular"
                            android:text="@string/dashboard_point_all"
                            android:textColor="@color/white_FFFFFF"
                            android:textSize="14sp" />
                    </RelativeLayout>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="32dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/panel_shop_management"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_action"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_action_shop" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:text="@string/dashboard_shop_management"
                            android:textColor="@color/gold_D4AF37"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/panel_user_management"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_action"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_action_user" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:text="@string/dashboard_user_management"
                            android:textColor="@color/gold_D4AF37"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/panel_point_history"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_action"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:adjustViewBounds="true"
                            android:contentDescription="@string/cd_icon"
                            android:src="@drawable/ic_history" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:text="@string/dashboard_point_history"
                            android:textColor="@color/gold_D4AF37"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:text="@string/dashboard_shop_management"
                        android:textColor="@color/white_FFFFFF"
                        android:textSize="20sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/textView_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/dashboard_shop_management_all"
                        android:textColor="@color/gold_D4AF37"
                        android:textSize="16sp" />
                </LinearLayout>

                <com.dj.manager.widget.ExpandableHeightListView
                    android:id="@+id/listView_shop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:listSelector="@android:color/transparent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginVertical="26dp"
                    android:fontFamily="@font/poppins_medium"
                    android:text="@string/copyright"
                    android:textColor="@color/gray_7E7E7E"
                    android:textSize="12sp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Drawer Menu (Side Menu) -->
    <include
        android:id="@+id/panel_side_menu"
        layout="@layout/view_side_menu" />
</androidx.drawerlayout.widget.DrawerLayout>